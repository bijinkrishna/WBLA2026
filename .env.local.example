# Supabase (get from https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: AI extraction for complaint field structuring
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Required for public Twilio WhatsApp webhook insert
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional but recommended: verify Twilio webhook signatures
TWILIO_AUTH_TOKEN=your-twilio-auth-token
